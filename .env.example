# Copy to .env and fill. .env is gitignored.
# Dev: direct Neon URL. Production: use the -pooler.neon.tech URL with pool.max:3.
DATABASE_URI=postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require
PAYLOAD_SECRET=generate_a_long_random_string
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
# Production media (Cloudflare R2 / S3) — fill at deploy:
# S3_BUCKET=
# S3_REGION=auto
# S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
